# systemd unit for the Good Guy Bad Guy classifier.
# Install (on the box):
#   sudo cp server/ggbg-classifier.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now ggbg-classifier
# HOME must point at the user whose Claude subscription is logged in, so
# `claude -p` finds ~/.claude and runs on the subscription (not a metered key).
[Unit]
Description=Good Guy Bad Guy cloud classifier
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Environment=HOME=/home/ubuntu
WorkingDirectory=/home/ubuntu/good-guy-bad-guy/server
ExecStart=/home/ubuntu/good-guy-bad-guy/server/run.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
