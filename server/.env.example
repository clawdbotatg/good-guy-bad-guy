# Copy to .env on the server and fill in. Loaded by run.sh / the systemd unit.
# NEVER commit the real .env.

# Shared secret the app sends in the X-Auth-Token header. Required.
GGBG_TOKEN=replace-with-a-long-random-secret

# Listen port. Non-standard on purpose.
GGBG_PORT=41821

# claude model alias for classification (sonnet = good vision + speed).
GGBG_MODEL=sonnet

# Max concurrent claude calls (protects the subscription).
GGBG_CONCURRENCY=3

# DEBUG ONLY: keep every image + both classifiers' output under data/.
# Leave unset / "0" in production — then images are deleted immediately and
# nothing is stored.
DEBUG_STORE=1

# Optional fallback classifier via the BANKR LLM gateway, used when claude is
# unavailable (and, in debug mode, always, for comparison). BANKR is a
# different provider than the box's Claude, so it survives a Claude outage.
# Leave BANKR_API_KEY blank to disable the fallback. Key starts with "bk_".
BANKR_API_KEY=
# Vision model for the fallback. Any vision-capable BANKR model works
# (gemini-3.1-flash-lite, gemini-2.5-flash, gpt-5.4-mini, gemma-4-31b-it, ...).
BANKR_MODEL=gemini-3.1-flash-lite
# BANKR_BASE_URL=https://llm.bankr.bot
